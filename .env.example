# docker compose가 읽는 루트 .env 예시

# Keycloak pickle-web confidential client secret.
# frontend/.env의 KEYCLOAK_CLIENT_SECRET과 같은 값으로 맞춘다.
KEYCLOAK_CLIENT_SECRET=pickle-web-secret

# Keycloak Google Identity Provider import에 사용된다.
# Google Cloud Console redirect URI:
# http://localhost:8180/realms/pickle/broker/google/endpoint
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
