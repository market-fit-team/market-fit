# docker compose가 읽는 루트 .env 예시

# authentik Docker Compose
# 공식 문서는 fresh install에서 PostgreSQL password와 AUTHENTIK_SECRET_KEY 생성을 권장합니다.
AUTHENTIK_TAG=2026.5
AUTHENTIK_HTTP_PORT=9000
PG_PASS=authentik-postgres-password-change-me
AUTHENTIK_SECRET_KEY=CHANGE_ME_60+_CHARS_RANDOM_VALUE
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=authentik
AUTHENTIK_BOOTSTRAP_TOKEN=CHANGE_ME_BOOTSTRAP_TOKEN
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# authentik OAuth2/OIDC Provider: pickle-web
# frontend/.env의 AUTHENTIK_CLIENT_SECRET과 같은 값으로 맞춘다.
AUTHENTIK_CLIENT_ID=pickle-web
AUTHENTIK_CLIENT_SECRET=pickle-web-secret

# authentik Google OAuth Source에 사용된다.
# Google Cloud Console Authorized redirect URI:
# http://localhost:9000/source/oauth/callback/google/
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
