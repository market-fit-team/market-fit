# LangGraph Agent Server
LANGGRAPH_CLI_NO_ANALYTICS=1
LANGSMITH_TRACING=false

# authentik JWT boundary
JWKS_URL=http://authentik-server:9000/application/o/pickle-web/jwks/
JWT_ISSUER=http://localhost:9000/application/o/pickle-web/
JWT_AUDIENCE=pickle-web
JWT_ALGORITHM=RS256

# agent-service 워크스페이스 DB와 내부 서비스 호출
DATABASE_URL=postgresql+asyncpg://agent:agent@agent-db:5432/agent
DATABASE_ECHO=false
AUTO_CREATE_SCHEMA=true
AGENT_SERVER_INTERNAL_URL=http://127.0.0.1:2024
ONBOARDING_SERVICE_URL=http://onboarding-service:8000
SERVICE_REQUEST_TIMEOUT_SECONDS=10

# Chat provider 설정입니다. API key 값은 로컬 .env에만 둡니다.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
GEMINI_API_KEY=
