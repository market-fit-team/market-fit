# LangGraph Agent Server
LANGGRAPH_CLI_NO_ANALYTICS=1
LANGSMITH_TRACING=false

# Better Auth / JWT boundary
# Next.js frontend의 Better Auth JWT plugin 설정과 반드시 맞춥니다.
JWKS_URL=http://host.docker.internal:3000/api/auth/jwks
JWT_ISSUER=http://localhost:3000
JWT_AUDIENCE=frontend-api
JWT_ALGORITHM=RS256

# Chat provider 설정입니다. API key 값은 로컬 .env에만 둡니다.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

# Gemini Embedding 2 / RAG 설정입니다.
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSION=768

# Qdrant RAG 저장소 설정입니다. 서비스 코드는 실제 collection이 아니라 alias를 바라봅니다.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=pickle_rag_embeddings_gemini2_768_v1
QDRANT_COLLECTION_ALIAS=pickle_rag_embeddings_current
QDRANT_DISTANCE=COSINE

# Java server가 검증해서 넘긴 signed URL 이미지를 가져오는 최대 대기 시간입니다.
MEDIA_FETCH_TIMEOUT_SECONDS=10
