# Database 설정
DB_HOST=community-db

# Redis 접속 설정
REDIS_HOST=community-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ 설정
RABBITMQ_HOST=community-rabbitmq

# S3 / MinIO
S3_ENDPOINT=http://community-minio:8900
S3_REGION=us-east-1
S3_BUCKET=pickle-post-images
S3_ACCESS_KEY=demo
S3_SECRET_KEY=demo12345
S3_PATH_STYLE_ACCESS=true
S3_PRESIGNED_URL_EXPIRATION_SECONDS=600

# Keycloak JWT boundary
JWKS_URL=http://keycloak:8080/realms/pickle/protocol/openid-connect/certs
JWT_ISSUER=http://localhost:8180/realms/pickle
JWT_AUDIENCE=pickle-api
