# .env.example

# Next.js는 compose 바깥에서 실행되어도 된다.
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="CHANGE_ME_32+_CHARS_RANDOM_VALUE"

# authentik은 compose 내부에서 실행되지만 브라우저/Next.js는 localhost:9000으로 접근한다.
# Better Auth Generic OAuth callback:
# http://localhost:3000/api/auth/oauth2/callback/authentik
AUTHENTIK_CLIENT_ID="pickle-web"
AUTHENTIK_CLIENT_SECRET="pickle-web-secret"
AUTHENTIK_DISCOVERY_URL="http://localhost:9000/application/o/pickle-web/.well-known/openid-configuration"

# 브라우저 런타임 API는 Next.js /api/proxy가 아니라 Traefik을 호출한다.
NEXT_PUBLIC_API_ORIGIN="http://localhost:8088"

# Orval codegen은 docker-compose.yml의 app.api.* labels를 읽고, OpenAPI는 Traefik을 통해 가져온다.

# LangGraph Agent
AGENT_ASSISTANT_ID="chat"
