# .env.example

# Next.js는 compose 바깥에서 실행되어도 된다.
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="CHANGE_ME_32+_CHARS_RANDOM_VALUE"
DATABASE_URL="postgres://postgres:postgres@localhost:5662/frontend_db"

# Keycloak은 compose 내부에서 실행되지만 브라우저/Next.js는 localhost:8180으로 접근한다.
# Better Auth Generic OAuth callback:
# http://localhost:3000/api/auth/oauth2/callback/keycloak
KEYCLOAK_CLIENT_ID="pickle-web"
KEYCLOAK_CLIENT_SECRET="pickle-web-secret"
KEYCLOAK_ISSUER="http://localhost:8180/realms/pickle"

# Google OAuth는 Better Auth가 직접 쓰지 않고 Keycloak Google Identity Provider import에 쓰인다.
# docker compose는 repo root .env를 읽으므로 compose 실행 시 같은 값을 root .env에도 둔다.
GOOGLE_CLIENT_ID="CHANGE_ME"
GOOGLE_CLIENT_SECRET="CHANGE_ME"

# 브라우저 런타임 API는 Next.js /api/proxy가 아니라 API Edge를 호출한다.
NEXT_PUBLIC_API_ORIGIN="http://localhost:8088"

# Orval codegen은 Discovery Server catalog와 OpenAPI proxy를 읽는다.
DISCOVERY_ORIGIN="http://localhost:8090"

# LangGraph Agent
AGENT_ASSISTANT_ID="chat"
