# .env.example

# Nginx gateway base (browser + server)
NEXT_PUBLIC_GATEWAY_BASE_URL="http://localhost:8080"
GATEWAY_BASE_URL="http://localhost:8080"

# Better Auth 필수
# BETTER_AUTH_SECRET: 최소 32자 이상 고엔트로피 시크릿 (공식 문서)
# https://better-auth.com/docs/installation :contentReference[oaicite:3]{index=3}
BETTER_AUTH_SECRET="CHANGE_ME_32+_CHARS_RANDOM"
BETTER_AUTH_URL="http://localhost:3000"

# PostgreSQL
DATABASE_URL="postgres://postgres:postgres@localhost:5662/frontend_db"

# Google OAuth2
# 리다이렉트 URI는 아래를 Google Cloud Console에 등록해야 합니다:
# http://localhost:3000/api/auth/callback/google
# https://your-domain.com/api/auth/callback/google
# https://better-auth.com/docs/authentication/google :contentReference[oaicite:4]{index=4}
GOOGLE_CLIENT_ID="CHANGE_ME"
GOOGLE_CLIENT_SECRET="CHANGE_ME"

# JWT (Next.js가 issuer)
# JWT 플러그인은 /api/auth/token + /api/auth/jwks 엔드포인트 제공 (공식 문서)
# https://better-auth.com/docs/plugins/jwt :contentReference[oaicite:5]{index=5}
JWT_ISSUER="http://localhost:3000"
JWT_AUDIENCE="frontend-api"
JWT_EXPIRATION="15m"

# Better Auth JWT 발급 알고리즘
# Better Auth는 "RS256" 알고리즘을 지원합니다.
# 적용 후 /api/auth/token의 JWT header alg가 "RS256"으로 나오는지 확인할 것.
# https://better-auth.com/docs/plugins/jwt
JWT_ALGORITHM="RS256"

# Orval codegen이 OpenAPI 문서를 받을 gateway origin
OPENAPI_GATEWAY_ORIGIN="http://localhost:8080"

# Server-side Orval fetch absolute origin.
# Client-side에서는 같은 origin이면 빈 문자열처럼 동작해도 되지만,
# 서버 fetch는 absolute URL이 안전하므로 localhost:3000을 둔다.
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"

# Next BFF가 browser/generated client에서 호출될 base
# 실제 Orval config에서는 /api/proxy/profile, /api/proxy/echo를 붙여 쓴다.
NEXT_PUBLIC_API_BASE_URL="/api/proxy"

# Next BFF가 Nginx upstream으로 보낼 base
UPSTREAM_API_BASE_URL="http://localhost:8080/api/"

